#!/bin/bash
# Backup script - Simple file backup utility

SOURCE="${1:-.}"
BACKUP_DIR="${BACKUP_DIR:-$HOME/backups}"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_NAME="backup_$(basename "$SOURCE")_$TIMESTAMP.tar.gz"

mkdir -p "$BACKUP_DIR"

echo "Creating backup of $SOURCE..."
tar -czf "$BACKUP_DIR/$BACKUP_NAME" "$SOURCE" 2>/dev/null

if [ -f "$BACKUP_DIR/$BACKUP_NAME" ]; then
    echo "Backup created: $BACKUP_DIR/$BACKUP_NAME"
    echo "Size: $(du -h "$BACKUP_DIR/$BACKUP_NAME" | cut -f1)"
else
    echo "Backup failed!"
    exit 1
fi